# =====================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================================
# Copy this file to .env and fill in your values
# =====================================================

# =====================================================
# NOTE: Blog and project API URLs are hardcoded in:
#   src/config/blogConfig.ts  (BLOG_CONFIG.API_URL)
#   src/config/projectsConfig.ts  (PROJECTS_CONFIG.API_URL)
# Edit those files directly to change the API endpoints.
# =====================================================

# =====================================================
# ANALYTICS & TRACKING (Optional)
# =====================================================
# Google Analytics ID (if you want to track visitors)
# REACT_APP_GA_ID=G-XXXXXXXXXX

# =====================================================
# CONTACT FORM (Optional)
# =====================================================
# Email service endpoint for contact form
# REACT_APP_CONTACT_ENDPOINT=

# =====================================================
# FEATURE FLAGS (Optional)
# =====================================================
# Enable/disable certain features
# REACT_APP_ENABLE_3D_ANIMATIONS=true
# REACT_APP_ENABLE_CONTACT_FORM=true
